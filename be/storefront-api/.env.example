# storefront-api (สาธารณะ)
PORT=3000
# secret แยกจาก admin — สุ่มยาว ๆ เช่น openssl rand -hex 32
STOREFRONT_JWT_SECRET=change-me-long-random
# โดเมนหน้าร้านที่อนุญาต (คั่นด้วย ,)
STOREFRONT_ORIGINS=http://localhost:8080,https://keyima.com
# ใช้ DB ไฟล์เดียวกับ admin ในช่วงแรก (path เดียวกัน)
DB_PATH=../shared/shop.db

# --- อีเมล (เว้นว่าง = โหมด dev: log แทนการส่งจริง) ---
MAIL_FROM=KEYIMA <no-reply@keyima.com>
SHOP_NAME=KEYIMA
# ตัวอย่าง SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey SMTP_PASS=<API_KEY>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
