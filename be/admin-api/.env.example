# admin-api (เฉพาะแอดมิน) — แยก secret/พอร์ต/โดเมนจาก storefront
PORT=4000
ADMIN_JWT_SECRET=change-me-different-long-random
# โดเมนหน้าแอดมินที่อนุญาตเท่านั้น (อย่าใส่โดเมนหน้าร้าน)
ADMIN_ORIGINS=http://localhost:5173,https://admin.keyima.com
# (แนะนำ) จำกัด IP ที่เข้าถึง admin API ได้ เช่น IP ออฟฟิศ/VPN — เว้นว่าง = ไม่จำกัด
ADMIN_IP_ALLOWLIST=
# บัญชีแอดมินเริ่มต้น (ใช้ตอน seed ครั้งแรกเท่านั้น)
ADMIN_USER=admin
ADMIN_PASS=change-this-now
DB_PATH=../shared/shop.db

# --- อีเมล (เว้นว่าง = โหมด dev: log แทนการส่งจริง) ---
MAIL_FROM=KEYIMA <no-reply@keyima.com>
SHOP_NAME=KEYIMA
# ตัวอย่าง SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey SMTP_PASS=<API_KEY>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
